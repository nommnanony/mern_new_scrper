
# === Application Configuration ===
NODE_ENV=production
PORT=3000

# === MongoDB Configuration ===
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mern-news-app?retryWrites=true&w=majority

# === Authentication ===
JWT_SECRET=your_secure_jwt_secret_key_min_32_chars_change_this_in_production

# === CORS Configuration ===
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# === News Scraper ===
HACKER_NEWS_URL=https://news.ycombinator.com

# === Optional: For monitoring/logging ===
# LOG_LEVEL=info
# SENTRY_DSN=https://your-sentry-dsn

